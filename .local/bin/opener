#!/bin/sh

mime=$(file --mime-type -b -L "$1")
ext="${1##*.}"

case "$mime" in
  text/*|application/csv|application/x-subrip|application/javascript|application/json|inode/x-empty)
    if [ "$ext" != "cue" ]; then
      $EDITOR "$1"
      exit 0
    fi
  ;;
  audio/*|image/*|video/*)
    m "$1" -quiet >/dev/null 2>&1 &
    exit 0
  ;;
esac

ra "$1" >/dev/null 2>&1 && exit 0

xdg-open "$1" > /dev/null 2> /dev/null &
