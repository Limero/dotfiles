#!/bin/sh

args=""
for arg in "$@"; do
  cleaned_arg=$(echo "$arg" | sed 's|^https://steamcommunity.com/linkfilter/?url=||')
  args="$args \"$cleaned_arg\""
done

if command -v firefox >/dev/null; then
  eval "firefox $args"
elif command -v org.mozilla.firefox >/dev/null; then
  eval "org.mozilla.firefox $args"
elif command -v termux-open-url >/dev/null; then
  eval "termux-open-url $args"
else
  echo 'No supported browser available'
fi
